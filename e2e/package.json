{
  "name": "e2e",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "wireit",
    "test:ui": "wireit",
    "test:angular:chromium": "wireit",
    "test:angular:firefox": "wireit",
    "test:angular:msedge": "wireit",
    "test:angular:webkit": "wireit",
    "test:lit:chromium": "wireit",
    "test:lit:firefox": "wireit",
    "test:lit:msedge": "wireit",
    "test:lit:webkit": "wireit",
    "test:svelte:chromium": "wireit",
    "test:svelte:firefox": "wireit",
    "test:svelte:msedge": "wireit",
    "test:svelte:webkit": "wireit",
    "test:vue:chromium": "wireit",
    "test:vue:firefox": "wireit",
    "test:vue:msedge": "wireit",
    "test:vue:webkit": "wireit",
    "test:report": "wireit"
  },
  "wireit": {
    "test": {
      "command": "playwright test",
      "files": [
        "tests/**/*.spec.ts",
        "playwright.config.ts",
        "tsconfig.json"
      ],
      "output": [
        "playwright-report/**",
        "test-results/**"
      ],
      "dependencies": [
        "../apps/angular-demo:build",
        "../apps/lit-demo:build",
        "../apps/svelte-demo:build",
        "../apps/vue-demo:build"
      ]
    },
    "test:ui": {
      "command": "playwright test --ui",
      "files": [
        "tests/**/*.spec.ts",
        "playwright.config.ts",
        "tsconfig.json"
      ],
      "service": true
    },
    "test:angular:chromium": {
      "command": "playwright test --project=angular-chromium",
      "files": [
        "tests/**/*.spec.ts",
        "playwright.config.ts",
        "tsconfig.json"
      ],
      "output": [
        "playwright-report/**",
        "test-results/**"
      ]
    },
    "test:angular:firefox": {
