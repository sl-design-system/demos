{
  "name": "angular-demo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "wireit",
    "lint": "wireit",
    "lint:fix": "wireit",
    "start": "wireit"
  },
  "wireit": {
    "build": {
      "command": "ng build",
      "files": [
        "angular.json",
        "tsconfig.json",
        "tsconfig.app.json",
        "src/**/*"
      ],
      "output": [
        "dist/**"
      ]
    },
    "lint": {
      "command": "eslint src/**/*.ts",
      "files": [
        "src/**/*.ts"
      ]
    },
    "lint:fix": {
      "command": "eslint src/**/*.ts --fix",
      "files": [
        "src/**/*.ts"
      ]
    },
    "start": {
      "command": "ng serve",
      "files": [
        "angular.json",
        "tsconfig.json",
        "tsconfig.app.json",
        "src/**/*"
      ],
      "service": true
    }
  },
  "dependencies": {
    "@angular/common": "^21.0.6",
    "@angular/compiler": "^21.0.6",
    "@angular/core": "^21.0.6",
    "@angular/forms": "^21.0.6",
    "@angular/platform-browser": "^21.0.6",
    "@angular/platform-browser-dynamic": "^21.0.6",
    "rxjs": "^7.8.2",
    "zone.js": "^0.16.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.3",
    "@angular-eslint/eslint-plugin": "^21.1.0",
    "@angular-eslint/eslint-plugin-template": "^21.1.0",
    "@angular-eslint/template-parser": "^21.1.0",
    "@angular/cli": "^21.0.3",
    "@angular/compiler-cli": "^21.0.6",
    "@typescript-eslint/types": "^8.50.0",
    "@typescript-eslint/utils": "^8.50.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "wireit": "^0.14.12"
  }
}
