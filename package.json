{
  "name": "demos-monorepo",
  "packageManager": "yarn@4.9.2",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "wireit",
    "format": "wireit",
    "lint": "wireit",
    "lint:fix": "wireit",
    "stylelint": "wireit",
    "stylelint:fix": "wireit"
  },
  "wireit": {
    "build": {
      "dependencies": [
        "./apps/angular-demo:build",
        "./apps/lit-demo:build",
        "./apps/svelte-demo:build",
        "./apps/vue-demo:build"
      ]
    },
    "format": {
      "command": "prettier --write .",
      "files": [
        "**/*.{js,ts,json,html,svelte,vue,css,scss,md}"
      ],
      "output": []
    },
    "lint": {
      "dependencies": [
        "./apps/angular-demo:lint",
        "./apps/lit-demo:lint",
        "./apps/svelte-demo:lint",
        "./apps/vue-demo:lint"
      ]
    },
    "lint:fix": {
      "dependencies": [
        "./apps/angular-demo:lint:fix",
        "./apps/lit-demo:lint:fix",
        "./apps/svelte-demo:lint:fix",
        "./apps/vue-demo:lint:fix"
      ]
    },
    "stylelint": {
      "command": "stylelint '**/*.{css,scss}'",
      "files": [
        "**/*.{css,scss}"
      ],
      "output": []
    },
    "stylelint:fix": {
      "command": "stylelint '**/*.{css,scss}' --fix",
      "files": [
        "**/*.{css,scss}"
      ],
      "output": []
    }
  },
  "dependencies": {
    "@angular/common": "^21.0.6",
    "@angular/core": "^21.0.6",
    "@angular/forms": "^21.0.6",
    "@angular/platform-browser": "^21.0.6",
    "@floating-ui/dom": "^1.7.4",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@lit-labs/virtualizer": "^2.1.1",
    "@lit/localize": "^0.12.2",
    "@open-wc/dedupe-mixin": "^2.0.1",
    "@open-wc/scoped-elements": "^3.0.6",
    "@sl-design-system/angular": "^4.0.1",
    "@sl-design-system/button": "^1.3.2",
    "@sl-design-system/checkbox": "^2.1.7",
    "@sl-design-system/dialog": "^2.0.2",
    "@sl-design-system/form": "^1.3.2",
    "@sl-design-system/icon": "^1.4.1",
    "@sl-design-system/listbox": "^0.1.6",
    "@sl-design-system/popover": "^1.2.6",
    "@sl-design-system/radio-group": "^1.1.6",
    "@sl-design-system/sanoma-learning": "^1.0.0",
    "@sl-design-system/select": "^2.1.0",
    "@sl-design-system/shared": "^0.9.2",
    "@sl-design-system/switch": "^1.1.5",
    "@sl-design-system/text-area": "^1.1.5",
    "@sl-design-system/text-field": "^1.6.6",
    "@sl-design-system/tooltip": "^1.3.0",
    "rxjs": "^7.8.2",
    "zone.js": "^0.16.0"
  },
  "devDependencies": {
    "@typescript-eslint/types": "^8.50.0",
    "@typescript-eslint/utils": "^8.50.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-lit": "^2.1.1",
    "eslint-plugin-lit-a11y": "^5.1.1",
    "eslint-plugin-svelte": "^3.13.1",
    "eslint-plugin-vue": "^10.6.2",
    "eslint-plugin-wc": "^3.0.2",
    "globals": "^16.5.0",
    "lit": "^3.3.1",
    "postcss": "^8.5.6",
    "postcss-lit": "^1.3.1",
    "prettier": "^3.7.4",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-config-standard-scss": "^16.0.0",
    "stylelint-order": "^7.0.0",
    "stylelint-prettier": "^5.0.3",
    "stylelint-use-logical": "^2.1.2",
    "svelte-eslint-parser": "^1.4.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vue-eslint-parser": "^10.2.0",
    "wireit": "^0.14.12"
  }
}
